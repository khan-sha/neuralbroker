local_nodes:
  - name: "ollama-default"
    runtime: "ollama"
    host: "localhost:11434"
    vram_threshold: 0.80
    gpu_index: 0

cloud_providers:
  - name: "groq"
    api_key_env: "GROQ_KEY"
    base_url: "https://api.groq.com/openai/v1"
    cost_per_1k_tokens: 0.00006

