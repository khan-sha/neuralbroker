routing:
  default_mode: "cost"
  vram_poll_interval_seconds: 0.5
  electricity_kwh_price: 0.14
  gpu_tdp_watts: 320

server:
  host: "0.0.0.0"
  port: 8000
  api_key_env: "NB_API_KEY"
