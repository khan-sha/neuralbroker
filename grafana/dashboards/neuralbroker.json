{
  "annotations": { "list": [] },
  "editable": true,
  "id": null,
  "title": "NeuralBroker",
  "uid": "neuralbroker",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "VRAM Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "nb_vram_utilization",
          "legendFormat": "GPU {{gpu_index}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 2,
      "title": "Routing Decisions / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "rate(nb_requests_total[1m])",
          "legendFormat": "{{backend}} ({{status}})"
        }
      ]
    },
    {
      "id": 3,
      "title": "Local vs Cloud Split",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "nb_tokens_local_total",
          "legendFormat": "Local"
        },
        {
          "expr": "nb_tokens_cloud_total",
          "legendFormat": "Cloud"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cost per Request",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(nb_cost_per_request_sum[5m]) / rate(nb_cost_per_request_count[5m])",
          "legendFormat": "{{backend}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "id": 5,
      "title": "Provider Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(nb_provider_errors_total[5m])",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Routing Latency (p95)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(nb_routing_latency_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 7,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "sum(nb_requests_total)",
          "legendFormat": "Total"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
